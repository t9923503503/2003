# server_restore.env.example
# Скопируйте в server_restore.env, заполните реальные значения и выполните:
#   source ./server_restore.env
#   bash server_restore.sh

# Database (PostgreSQL)
export DB_NAME="lpbvolley"
export DB_USER="lpbvolley"
export DB_PASS="<CHANGE_ME_DB_PASSWORD>"

# PostgREST
export POSTGREST_JWT_SECRET="<CHANGE_ME_JWT_SECRET>"

# Site + SSL (Let's Encrypt)
export SITE_DOMAIN="sv-ugra.ru"
export SITE_EMAIL="admin@sv-ugra.ru"

# App repository
export APP_REPO="https://github.com/t9923503503/2003.git"
export APP_BRANCH="main"
export APP_PATH="/var/www/ipt"

# App config.js (API base + anon key)
# Пример для PostgREST за nginx: https://<domain>/api
export APP_API_BASE="https://sv-ugra.ru/api"
export APP_SUPABASE_ANON_KEY="<CHANGE_ME_ANON_KEY>"

